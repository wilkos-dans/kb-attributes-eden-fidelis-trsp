@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix trsp: <https://github.com/wimhugo/kb-attributes-eden-fidelis-trsp/> .

trsp:checklistAAI
  a skos:ConceptScheme ;
  skos:prefLabel "Checklist for AAI Protocols"@en ;
  dct:title "Checklist for AAI"@en ;
  dct:description "List of AAI protocols available"@en ;
  dct:created "2026-07-03T00:00:00+00:00"^^xsd:datetime ;
  dct:creator <https://orcid.org/0000-0002-0255-5101> ;
  owl:versionInfo "0.1" .

trsp:aai-saml
  a skos:Concept ;
  skos:prefLabel "SAML"@en ;
  skos:inScheme trsp:checklistAAI .

trsp:aai-oauth2
  a skos:Concept ;
  skos:prefLabel "OAuth-2"@en ;
  skos:inScheme trsp:checklistAAI .

trsp:aai-openid
  a skos:Concept ;
  skos:prefLabel "OpenIDConnect"@en ;
  skos:inScheme trsp:checklistAAI .

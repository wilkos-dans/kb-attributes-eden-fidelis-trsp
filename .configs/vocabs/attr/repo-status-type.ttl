@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix trsp: <https://github.com/wimhugo/kb-attributes-eden-fidelis-trsp/> .

trsp:repo-status-type-scheme
  a skos:ConceptScheme ;
  skos:prefLabel "Repository Status"@en ;
  dct:title "Repository Status"@en ;
  dct:created "2026-05-07"^^xsd:date ;
  dct:modified "2026-05-07"^^xsd:date ;
  owl:versionInfo "0.1" .

trsp:operational
  a skos:Concept ;
  skos:prefLabel "Operational"@en ;
  skos:inScheme trsp:repo-status-type-scheme .

trsp:beta
  a skos:Concept ;
  skos:prefLabel "Beta"@en ;
  skos:inScheme trsp:repo-status-type-scheme .

trsp:planned
  a skos:Concept ;
  skos:prefLabel "Planned"@en ;
  skos:inScheme trsp:repo-status-type-scheme .

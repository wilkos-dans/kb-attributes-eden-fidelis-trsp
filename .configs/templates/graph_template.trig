# ============================================================
# TRSP Graph Template (TriG format)
# Sections are populated from TTL source files via the pipeline.
# ============================================================

@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix vcard: <http://www.w3.org/2006/vcard/ns#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix openrel: <https://w3id.org/openrel/> .

# ==================================================================================================================
# SECTION 1: PROVENANCE AND METADATA
# Describes the dataset itself — who generated it, when, and how.
# ==================================================================================================================
openrel:provenanceGraph {
    openrel:dataset a dct:Dataset ;
        dct:title "TRSP Repository or Service Graph Template" ;
        dct:description "Populated graph of repository nodes with support nodes for contacts and institutions." ;
        dct:created "TEMPLATE_DATE"^^xsd:date ;
        dct:modified "TEMPLATE_DATE"^^xsd:date ;
        dct:hasVersion "1.0" ;
        dct:publisher openrel:org-publisher ;
        prov:wasGeneratedBy openrel:curationActivity .

    openrel:curationActivity a prov:Activity ;
        prov:startedAtTime "TEMPLATE_DATE"^^xsd:dateTime ;
        prov:wasAssociatedWith openrel:org-publisher ;
        rdfs:label "Automated graph curation" .
}

# ==================================================================================================================
# SECTION 2: MAIN NODES (Repository Nodes)
# Primary entities being curated. Each main node references
# support nodes by IRI (contacts, institutions, services, checklists, etc.).
# Populated from TTL source files containing repository, person, institution, checklists, etc. properties.
# ==================================================================================================================
openrel:mainNodesGraph {
    # --- Repository nodes are inserted here ---
    # Example:
    # openrel:repo-001 a dcat:Repository ;
    #     dct:title "Example Repository" ;
    #     dct:description "A research data repository." ;
    #     openrel:hasContact openrel:person-001 ;
    #     openrel:hasInstitution openrel:org-001 .
}

# ==================================================================================================================
# SECTION 3: MAIN NODES (Service Nodes)
# Primary entities being curated. Each main node references
# support nodes by IRI (contacts, institutions, services, checklists, etc.).
# Populated from TTL source files containing repository, person, institution, checklists, etc. properties.
# ==================================================================================================================
openrel:mainNodesGraph {
    # --- Service nodes are inserted here ---
    # Example:
    # openrel:service-001 a dcat:Service ;
    #     dct:title "Example Service" ;
    #     dct:description "A repository service." ;
    #     trsp:serviceType skos:Concept - must come from .configs/vocabs/eosc/service-type.ttl
    #     openrel:hasContact openrel:person-001 ;
    #     openrel:hasInstitution openrel:org-001 .
}

# ==================================================================================================================
# SECTION 4: SUPPORT NODE SECTIONS
# Reusable complex objects referenced by main nodes.
# Populated from dedicated TTL files — one file per support type.
# ==================================================================================================================

# --- 4a: Contact Persons (vcard objects) ---
openrel:supportContactsGraph {
    # --- Contact person nodes are inserted here ---
    # Example:
    # openrel:person-001 a vcard:Individual ;
    #     vcard:fn "Jane Doe" ;
    #     vcard:hasEmail <mailto:jane.doe@example.org> ;
    #     vcard:hasTelephone <tel:+3100000000> .
}

# --- 4b: Institutions (foaf objects, reused across repositories) ---
openrel:InstitutionsGraph {
    # --- Institution nodes are inserted here ---
    # Example:
    # openrel:org-001 a foaf:Organization ; # This can be a registry identifier if applicable
    #     foaf:name "University X" ;
    #     foaf:homepage <https://university-x.example.org> ;
    #     openrel:hasRorId <https://ror.org/000000000> ;
    #     openrel:institutionRole skos:Concept - must come from .configs/vocabs/attr/institution-role-type.ttl
    .
}

# --- 4c: Checklists (openrel checklist objects) ---
openrel:checklistGraph {
    # --- Checklist nodes are inserted here ---
    # Example:
    # openrel:check-001 a openrel:Checklist ;
    #     openrel:checklistSource "" # must come from one of '.configs/vocabs/attr' vocabularies
    #     openrel:checkItems  
    #        [ a openrel:ChecklistItem ;
    #          openrel:checklistIRI "" # a concept IRI from a vocabulary at '.configs/vocabs/attr vocabularies'
    #          openrel:evidenceIRL ""^^xsd:anyURI ],
    #        [ a openrel:ChecklistItem ;
    #          openrel:checklistIRI "" # a concept IRI from a vocabulary at '.configs/vocabs/attr vocabularies'
    #          openrel:evidenceIRL ""^^xsd:anyURI ]
    #     .
}
